{
    "compilerOptions": {
		"declaration": true,
		"allowJs": true,
		"jsx": "react-jsx",
		"target": "ES2020",
		"module": "ES2020",
		"moduleResolution": "node",
		"esModuleInterop": true,
    	"experimentalDecorators": true,
    	"allowSyntheticDefaultImports": true,
		"resolveJsonModule": true,
		"noImplicitAny": true,
		"strictNullChecks": true,
		"lib": ["dom", "es6", "ESNext"],
		"baseUrl": ".",
		"paths": {
            "@flyva/shared": ["packages/shared"],
            "@flyva/shared/*": ["packages/shared/*"],
            "@flyva/nuxt": ["packages/nuxt"],
            "@flyva/next": ["packages/next"],
        }
	},
	"exclude": [
		"node_modules"
	],
	"include": [
		"**/*.ts",
		"**/*.json"
	]
}
